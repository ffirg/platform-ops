---
# inventory/aap.yml
# AAP Infrastructure Inventory - Auto-generated by discover-aap-inventory.yml
#
# Generated: {{ lookup('pipe', 'date -u +%Y-%m-%dT%H:%M:%SZ') }}
# Source: https://{{ aap_hostname }}/api/gateway/v1/service_nodes/
#
# To regenerate:
#   ansible-playbook playbooks/discover-aap-inventory.yml -e discovery_mode=write_file
#
# Or use dynamic discovery:
#   ansible-playbook playbooks/check-aap-certs.yml

all:
  children:
{% for service in discovered_aap_services %}
    aap_{{ service }}:
      hosts:
{% for node in discovered_aap_nodes %}
{% if service in discovered_host_services[node] %}
        {{ node }}:
{% endif %}
{% endfor %}

{% endfor %}
  vars:
    # Default platform for certificate discovery
    aap_platform: containerized

    # Certificate check thresholds
    cert_warning_days: 30
    cert_critical_days: 14

    # AAP containerized service certificate paths (podman)
    # These are checked automatically by check-aap-certs.yml
    aap_container_services:
      # Controller
      - automation-controller-web
      - automation-controller-task
      - automation-controller-rsyslog
      # Hub
      - automation-hub-api
      - automation-hub-content
      - automation-hub-web
      - automation-hub-worker-1
      - automation-hub-worker-2
      # EDA
      - automation-eda-api
      - automation-eda-daphne
      - automation-eda-scheduler
      - automation-eda-web
      - automation-eda-worker-1
      - automation-eda-worker-2
      - automation-eda-activation-worker-1
      - automation-eda-activation-worker-2
      # Gateway
      - automation-gateway
      - automation-gateway-proxy
      # Infrastructure
      - postgresql
      - receptor
      - redis-tcp
      - redis-unix
      # MCP
      - ansiblemcp
