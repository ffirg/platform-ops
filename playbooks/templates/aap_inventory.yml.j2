---
# inventory/aap.yml
# AAP Infrastructure Inventory - Auto-generated by discover-aap-inventory.yml
#
# Generated: {{ ansible_date_time.iso8601 | default(lookup('pipe', 'date -u +%Y-%m-%dT%H:%M:%SZ')) }}
# Source: https://{{ aap_hostname }}/api/gateway/v1/service_nodes/
#
# To regenerate:
#   ansible-playbook playbooks/discover-aap-inventory.yml
#
# Or use the dynamic inventory instead:
#   ansible-playbook playbooks/check-aap-certs.yml -i plugins/inventory/aap_gateway.py

all:
  children:
{% for service_type_id in service_ids %}
{% set service_name = service_type_map[service_type_id] %}
    aap_{{ service_name }}:
      hosts:
{% for node in _service_nodes.json.results | selectattr('summary_fields.service_cluster.service_type', 'eq', service_type_id) %}
        {{ node.address }}:
{% endfor %}

{% endfor %}
  vars:
    # Default platform for certificate discovery
    aap_platform: containerized

    # Certificate check thresholds
    cert_warning_days: 30
    cert_critical_days: 14

    # AAP containerized service certificate paths (podman)
    # These are checked automatically by check-aap-certs.yml
    aap_container_services:
      - automation-controller-web
      - automation-controller-task
      - automation-hub-api
      - automation-hub-web
      - automation-eda-api
      - automation-eda-web
      - automation-gateway
      - redis
      - postgresql
